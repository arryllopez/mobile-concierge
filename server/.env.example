# Copy to ".env" and adjust as needed.

# Port the API listens on.
PORT=4000

# Secret used to sign JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=dev-only-change-me

# How long an auth token stays valid.
JWT_EXPIRES_IN=7d

# Path to the SQLite database file (relative to the server package).
DATABASE_PATH=./data/concierge.db

# Default lifetime of a broadcast message, in days.
BROADCAST_DEFAULT_DAYS=30
